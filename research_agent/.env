# ── App ──────────────────────────────────────────────────────
APP_NAME=ResearchAgent
APP_VERSION=1.0.0
DEBUG=false

# ── Database ─────────────────────────────────────────────────
# For local dev (without Docker): point to your local Postgres.
# For Docker: overridden in docker-compose.yml automatically.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/research_agent

# ── External API Base URLs ────────────────────────────────────
MCA_BASE_URL=https://api.mca21.gov.in/v1
GSTN_BASE_URL=https://api.mastergst.com/gstnapi/taxpayerDetails
ECOURTS_BASE_URL=https://ecourts.gov.in/ecourts_home
RBI_BASE_URL=https://www.rbi.org.in

# ── Tavily API (News Search) ──────────────────────────────────
# Get your key at: https://tavily.com
# Leave empty to skip news source.
TAVILY_API_KEY=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

# ── Scoring Thresholds ────────────────────────────────────────
BASE_SCORE=100
REJECTION_THRESHOLD=0
HIGH_RISK_THRESHOLD=40
MEDIUM_RISK_THRESHOLD=70

# ── Timeouts ──────────────────────────────────────────────────
SOURCE_TIMEOUT_SECONDS=30
